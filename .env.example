# Orbit — environment variables
# Copy to .env for local dev, or set these in Koyeb for production.
# NEVER commit the real .env (it's git-ignored).

# ---- Discord bot ----
TOKEN=your-bot-token
CLIENT_ID=your-application-id
GUILD_ID=                       # optional: set for instant guild-only slash commands

# ---- Website / OAuth ----
CLIENT_SECRET=your-oauth-client-secret
SESSION_SECRET=any-long-random-string
# In production set these to your public URL (e.g. https://orbit-xxxx.koyeb.app)
WEB_BASE_URL=http://localhost:3000
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# PORT is injected automatically by Koyeb; WEB_PORT is only for local runs.
WEB_PORT=3000

# ---- Branding (optional public image URLs) ----
LOGO_URL=
BANNER_URL=

# ---- Database (Turso / libSQL) ----
# Leave BLANK for local dev (uses database/database.sqlite).
# In production set to your Turso database URL + auth token.
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=

# ---- Admins (comma-separated Discord user IDs) ----
ADMIN_IDS=

# ---- Dodo Payments ----
DODO_PAYMENTS_API_KEY=
DODO_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_PREMIUM=
DODO_PRODUCT_PRO=
